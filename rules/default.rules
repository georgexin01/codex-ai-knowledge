prefix_rule(pattern=["C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Get-ChildItem -Force .vscode | Select-Object Name,Length,LastWriteTime"], decision="allow")
prefix_rule(pattern=["C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "claude --version"], decision="allow")
prefix_rule(pattern=["C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "claude.cmd --version"], decision="allow")
prefix_rule(pattern=["C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "node -v"], decision="allow")
prefix_rule(pattern=["C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "npm ls -g @anthropic-ai/claude-code --depth=0"], decision="allow")
prefix_rule(pattern=["C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "npm.cmd ls -g @anthropic-ai/claude-code --depth=0"], decision="allow")
prefix_rule(pattern=["C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "npm.cmd install -g @anthropic-ai/claude-code@latest"], decision="allow")
prefix_rule(pattern=["C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Get-Content -LiteralPath 'C:\\Users\\user\\.codex\\memories\\MEMORY.md' | Select-String -Pattern 'codex|CODEX_FULL_ACCESS_ROUTING|CODEX_DYNAMIC_ROUTING|ROUTER.idx|ATLAS.idx' -Context 0,2"], decision="allow")
prefix_rule(pattern=["C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "& 'C:\\Users\\user\\.codex\\codex-router\\Update-CodexRouting.ps1' -Quiet"], decision="allow")
prefix_rule(pattern=["C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Select-String -LiteralPath 'C:\\Users\\user\\.codex\\memories\\MEMORY.md' -Pattern 'Task Group: Windows Codex|ROUTER.idx and ATLAS.idx|Update-CodexRouting.ps1|libraries\\\\codex-migrated' -Context 0,0 | ForEach-Object { \"$($_.LineNumber):$($_.Line)\" }"], decision="allow")
prefix_rule(pattern=["C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Select-String -LiteralPath 'C:\\Users\\user\\.codex\\memories\\MEMORY.md' -Pattern 'ROUTER.idx' -Context 0,0 | ForEach-Object { \"$($_.LineNumber):$($_.Line)\" }"], decision="allow")
